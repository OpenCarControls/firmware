{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "probe-rs-debug",
            "request": "launch",
            "name": "Debug: ESP32-S3 (probe-rs)",
            "preLaunchTask": "Build: ESP32-S3 firmware (debug)",
            "chip": "esp32s3",
            "flashingConfig": {
                "flashingEnabled": true,
                "resetAfterFlashing": true,
                "haltAfterReset": true
            },
            "coreConfigs": [
                {
                    "coreIndex": 0,
                    "programBinary": "${workspaceFolder}/.app_build/target/xtensa-esp32s3-none-elf/debug/app-build"
                }
            ]
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug: PC board (app-build)",
            "preLaunchTask": "Build: app-build (debug)",
            "program": "${workspaceFolder}/.app_build/target/debug/app-build",
            "args": [],
            "cwd": "${workspaceFolder}",
            "env": {
                "RUST_LOG": "info"
            }
        }
    ]
}
